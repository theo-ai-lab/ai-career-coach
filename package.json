{
  "name": "ai-career-coach",
  "version": "0.3.0",
  "private": true,
  "description": "AI career coach for resume-grounded coaching, with a preregistered honesty / grounding eval benchmark and adversarial red-team.",
  "author": "Theo Bermudez",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theo-ai-lab/ai-career-coach.git"
  },
  "keywords": [
    "rag",
    "career-coach",
    "llm-evals",
    "adversarial-red-team",
    "langgraph",
    "nextjs",
    "supabase",
    "pgvector"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test lib/quality-gates/*.test.ts lib/grounding/*.test.ts lib/demo/*.test.ts lib/*.test.ts",
    "test:quality-gates": "tsx --test lib/quality-gates/*.test.ts",
    "test:grounding": "tsx --test lib/grounding/*.test.ts",
    "test:demo": "tsx --test lib/demo/*.test.ts",
    "check:claims": "tsx scripts/calibrate-ood-gate.ts --check && tsx scripts/ci/check-calibration-docs.ts && tsx scripts/ci/check-readme-sentence.ts",
    "check:coverage": "node scripts/ci/check-coverage-counts.mjs",
    "check:demo": "tsx scripts/build-demo-artifacts.ts --check",
    "verify:live": "node scripts/verify-live.mjs"
  },
  "dependencies": {
    "@langchain/community": "^1.0.4",
    "@langchain/core": "^1.0.6",
    "@langchain/langgraph": "^1.0.2",
    "@langchain/openai": "^1.1.2",
    "@langchain/textsplitters": "^1.0.0",
    "@napi-rs/canvas": "^0.1.83",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.84.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "langchain": "^1.0.6",
    "lucide-react": "^0.554.0",
    "next": "16.1.3",
    "next-themes": "^0.4.6",
    "pdf-parse": "^1.1.4",
    "posthog-js": "^1.297.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tsx": "^4.20.6",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
