# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Proactive secrets / credential fence
*.key
*.crt
*.p12
id_rsa*
*.sqlite
*.sqlite3

# IDE / editor (each developer decides whether to commit their own)
.idea/
.vscode/

# Claude Code session state (per-machine, never commit)
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# cursor mcp configuration (contains API keys)
.cursor/

# cursor rules (local workflow prompts)
/

# Never commit personal research PDFs
*.pdf
grok_chats/
dev-error.log
.next
.next 2

# project instructions for AI assistant — local only
CLAUDE.md

# macOS Finder duplicates
* 2.md
* 2.sql
* 2.json
* 2.ts
./
.gbrain-source
