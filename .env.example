# =============================================================================
# Required: production app
# =============================================================================

# OpenAI key. Used for embeddings (text-embedding-3-small) and generation
# (gpt-4o-mini). Get from https://platform.openai.com/api-keys.
OPENAI_API_KEY=

# Supabase project URL — the https://xxxx.supabase.co prefix.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key. Used by client and server-side anon-role queries
# (chat UI, eval reads in production).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key. Used server-side by /api/upload (inserts into
# the documents table). KEEP SECRET — bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Optional: analytics
# =============================================================================

# PostHog project key. App runs fine without these — analytics is
# best-effort. Get from https://us.posthog.com/project/<id>/settings.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# =============================================================================
# Optional: eval benchmark only (scripts/run-eval-benchmark.cjs)
# =============================================================================
# Required for cross-model and cross-embedding experiments documented in
# data/eval-benchmark/README.md. Not used by the application at runtime. Stub
# entries so a fresh clone knows which extra keys the benchmark expects.

# OpenRouter unified API. Used for cross-model generation (multi-vendor /
# open-weights). Get from https://openrouter.ai/keys.
OPENROUTER_API_KEY=

# Voyage AI embeddings (alternative to OpenAI's). Cross-embedding
# experiment only (planned, not wired into the live app). https://www.voyageai.com.
VOYAGE_API_KEY=

# Cohere embeddings (alternative). Cross-embedding experiment only
# (planned, not wired into the live app). https://dashboard.cohere.com/api-keys.
COHERE_API_KEY=

# Google Gemini API key. Cross-embedding experiment only (planned, not
# wired into the live app). https://aistudio.google.com/app/apikey.
GEMINI_API_KEY=

# =============================================================================
# Optional: adversarial red-team harness (scripts/red-team.mjs)
# =============================================================================
# Target deployment the red-team prompts run against (defaults to
# http://localhost:3000), plus an optional pre-uploaded resume to reuse.
RED_TEAM_BASE_URL=
RED_TEAM_PDF_PATH=
RED_TEAM_RESUME_ID=
